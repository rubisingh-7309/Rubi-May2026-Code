## 🔹 Ansible Task — Install Nginx on Pathnex Server

Rewrite this YAML manually:

---
- name: Install Nginx Server on Pathnex Server  
  hosts: all
  become: yes
  tasks:
    - name: Install nginx
      yum:
        - name: nginx
          state: present


## 🔹 Terraform Task — Create EC2 (c5.xlarge)
provider "aws" {
    region = "eu-north-1"
}

resource "aws_instance" "rubi" {
    ami            =  "ami-0abcd1234abcd1234"
    instance_type  =   "m7i-flex.large"

    tags = {
        Name = "Rubi-EC2"
    }
}

## 🔹 Kubernetes Task — Create Nginx Pod

apiVersion: v1
kind: pod
metadata: 
   name: rubi-pod
spec:
  containers:
     - name: web
       image: nginx:latest
       ports: 
        containerPort: 80

