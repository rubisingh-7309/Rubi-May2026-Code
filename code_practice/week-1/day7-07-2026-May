3. Kubernetes: Deployment 2 replicas

apiVersion: apps/v1
kind: Deployment
metadata:
   name: "pathnex-deployment"
spec:
   replicas: 2
   selector:
      matchLabels:
        app: nginx
   template:
      metadata:
        labels:
           app: nginx
      spec:
        containers:
            - name: nginx-container
              image: nginx
              ports:
                - containerPort: 80     

